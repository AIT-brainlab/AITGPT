      "updated": 1779707907691,
      "link": null,
      "locked": false,
      "text": "AITGPT trigger the\n/api/validate with student data.\n\n1. CC module performs\nRDF_convertor\n2. CC module performs pyshacl\nto check compliance\n3. CC module answer with True,\nFalse",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
